# =============================================================================
# OpenClaw Safe-Box — .env.example
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then run setup.sh (Mac/Linux) or setup.ps1 (Windows) — it will walk you
# through the required fields and generate the gateway token automatically.
#
# IMPORTANT: Never commit .env to version control. It contains secrets.
# =============================================================================


# =============================================================================
# REQUIRED — OpenClaw will not start without these
# =============================================================================

# Gateway token — authenticates your browser to the Control UI.
# Generated automatically by setup.sh. Do not set this by hand unless you
# know what you're doing. Do not share it or store it in a password manager
# that syncs to the cloud.
OPENCLAW_GATEWAY_TOKEN=


# =============================================================================
# REQUIRED — Set at least one AI provider
# =============================================================================

# Anthropic (Claude models — recommended)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI (GPT models — alternative)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=


# =============================================================================
# MESSAGING CHANNELS — Set whichever channels you want to use
#
# You can also add channels later through the Control UI at localhost:18789,
# or by running: ./add-channel.sh <channel-name>
# =============================================================================

# Telegram
# Create a bot via @BotFather on Telegram and paste the token here.
# Guide: https://core.telegram.org/bots/tutorial#getting-ready
TELEGRAM_BOT_TOKEN=

# Discord
# Create a bot at https://discord.com/developers/applications
# Enable: Server Members Intent, Message Content Intent
DISCORD_BOT_TOKEN=

# Slack
# Requires both a bot token (xoxb-...) and an app-level token (xapp-...)
# Guide: https://docs.openclaw.ai/channels/slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=


# =============================================================================
# OPTIONAL — Customisation
# =============================================================================

# Docker image to use. Defaults to the latest official release.
# Pin to a specific version for stability, e.g.:
#   OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:1.4.2
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Host directory mounted as the agent's workspace.
# This is the ONLY folder on your laptop the container can access.
# Defaults to ~/openclaw-workspace (created by setup.sh if it doesn't exist).
# Use an absolute path if you prefer a different location.
OPENCLAW_WORKSPACE=~/openclaw-workspace

# Timezone for log timestamps and any time-aware skills.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
